# Python / uv
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Secrets — never commit the real .env (.env.example is committed).
.env

# Large wordlists — downloaded via scripts/fetch_wordlists.sh, not committed.
# The small starter list (common.txt) IS committed as a fallback.
app/wordlists/*
!app/wordlists/common.txt
!app/wordlists/.gitkeep
